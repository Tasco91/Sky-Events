<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SKY EVENTS Co. — Where Vision Meets Spectacle</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&family=Tenor+Sans&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#B8902A; --gold2:#D4AF5A; --gold3:#EDD88A; --gold-bg:#FDF8EC;
  --champagne:#FAF3E0; --cream:#FDFAF5; --offwhite:#F9F6EE;
  --warm:#F5EDD6; --warm2:#EDE0C4;
  --navy:#0C2340; --navy2:#163352;
  --text:#1A1408; --muted:#7A6A50; --muted2:#A89070;
  --border:rgba(184,144,42,0.18); --border2:rgba(184,144,42,0.3);
  --white:#fff;
}
*{margin:0;padding:0;box-sizing:border-box;} html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:var(--cream);color:var(--text);}

/* ── NAV ── */
nav{
  position:fixed;top:0;width:100%;z-index:200;
  display:flex;justify-content:space-between;align-items:center;
  padding:1.1rem 5%;
  background:rgba(253,250,245,0.97);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border2);
  box-shadow:0 2px 30px rgba(184,144,42,0.08);
}
.nav-brand{display:flex;align-items:center;gap:0.9rem;text-decoration:none;}
.nb-text{line-height:1.1;}
.nb-name{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:var(--text);letter-spacing:3px;display:block;}
.nb-name .g{color:var(--gold);}
.nb-sub{font-size:0.48rem;letter-spacing:3.5px;text-transform:uppercase;color:var(--muted2);font-weight:500;display:block;margin-top:1px;}
nav ul{list-style:none;display:flex;gap:2.5rem;align-items:center;}
nav a{text-decoration:none;color:var(--muted);font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;transition:color 0.3s;font-weight:600;}
nav a:hover{color:var(--gold);}
.nav-cta{background:var(--gold);color:var(--white)!important;padding:0.65rem 1.6rem;border-radius:2px;font-weight:700!important;letter-spacing:2px;}
.nav-cta:hover{background:var(--navy)!important;}

/* ── HERO ── */
.hero{
  min-height:100vh;position:relative;display:grid;
  grid-template-columns:1fr 1fr;align-items:center;
  padding:8rem 5% 5rem;gap:4rem;overflow:hidden;
  background:linear-gradient(160deg,var(--cream) 0%,var(--champagne) 50%,var(--gold-bg) 100%);
}
/* Elegant gold pattern overlay */
.hero::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background-image:
    radial-gradient(circle at 80% 20%, rgba(184,144,42,0.06) 0%, transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(184,144,42,0.04) 0%, transparent 40%);
}
/* Decorative geo lines */
.hero-deco{position:absolute;right:0;top:0;width:50%;height:100%;pointer-events:none;overflow:hidden;}
.hero-deco::before{content:'';position:absolute;width:700px;height:700px;border:1px solid rgba(184,144,42,0.1);border-radius:50%;right:-200px;top:-150px;}
.hero-deco::after{content:'';position:absolute;width:450px;height:450px;border:1px solid rgba(184,144,42,0.08);border-radius:50%;right:-50px;top:-30px;}

.hero-left{position:relative;z-index:2;}
.hero-pretitle{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;}
.pre-line{width:45px;height:1.5px;background:var(--gold);}
.pre-text{font-size:0.62rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:700;}
.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(4rem,7vw,7.5rem);
  line-height:0.9;letter-spacing:-1px;color:var(--text);margin-bottom:1.2rem;
}
.hero h1 .gold-h{color:var(--gold);}
.hero h1 .italic-h{font-style:italic;color:var(--muted);}
.hero-tagline{
  font-family:'Cormorant Garamond',serif;font-style:italic;
  font-size:1.3rem;color:var(--gold);margin-bottom:1.5rem;
  font-weight:400;letter-spacing:0.5px;
}
.hero p{color:var(--muted);font-size:0.88rem;line-height:2.1;font-weight:300;margin-bottom:2.8rem;max-width:480px;}
.hero-btns{display:flex;gap:1.2rem;flex-wrap:wrap;align-items:center;}
.btn-gold{background:var(--gold);color:var(--white);padding:1.1rem 2.8rem;text-decoration:none;border-radius:2px;font-weight:700;font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;transition:all 0.3s;box-shadow:0 8px 30px rgba(184,144,42,0.25);}
.btn-gold:hover{background:var(--navy);transform:translateY(-3px);box-shadow:0 15px 40px rgba(12,35,64,0.2);}
.btn-ghost-dark{border:1.5px solid var(--border2);color:var(--gold);padding:1.1rem 2.8rem;text-decoration:none;border-radius:2px;font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;font-weight:600;transition:all 0.3s;}
.btn-ghost-dark:hover{background:var(--gold);color:var(--white);border-color:var(--gold);}

/* Right side — luxury logo showcase */
.hero-right{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:1.5rem;}
.luxury-card{
  background:var(--white);border:1px solid var(--border2);border-radius:4px;
  padding:3rem 2.5rem;display:flex;flex-direction:column;align-items:center;
  gap:1rem;text-align:center;width:310px;
  box-shadow:0 20px 70px rgba(184,144,42,0.12), 0 4px 20px rgba(0,0,0,0.04);
  position:relative;overflow:hidden;
}
.luxury-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold3),var(--gold),var(--gold3));}
.lc-divider{width:50px;height:1px;background:var(--gold2);}
.lc-name{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--text);letter-spacing:4px;}
.lc-name .g{color:var(--gold);}
.lc-tag{font-size:0.55rem;letter-spacing:4px;text-transform:uppercase;color:var(--muted2);font-weight:600;}
.lc-contact-name{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:600;color:var(--text);}
.lc-contact-detail{font-size:0.68rem;color:var(--muted);letter-spacing:0.5px;}
.lc-contact-detail span{color:var(--gold);font-weight:600;}

/* Floating stat chips */
.stat-chips{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;width:310px;}
.stat-chip{background:var(--white);border:1px solid var(--border);border-radius:3px;padding:1rem;text-align:center;box-shadow:0 4px 15px rgba(184,144,42,0.07);}
.sc-n{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--gold);line-height:1;}
.sc-l{font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted2);font-weight:600;margin-top:0.2rem;}

/* ── GOLD STATS BAND ── */
.stats-band{
  background:var(--gold);padding:2.2rem 5%;
  display:flex;justify-content:center;gap:6rem;flex-wrap:wrap;
}
.sband-item{text-align:center;}
.sband-n{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:700;color:var(--white);line-height:1;}
.sband-l{font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.7);margin-top:0.3rem;font-weight:600;}

/* ── SECTIONS ── */
.section{padding:7rem 5%;}
.sec-pretitle{display:flex;align-items:center;gap:0.8rem;margin-bottom:0.8rem;}
.spt-line{width:30px;height:1.5px;background:var(--gold);}
.spt-text{font-size:0.6rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:700;}
.sec-h{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:600;line-height:1.1;margin-bottom:1rem;color:var(--text);}
.sec-h em{font-style:italic;color:var(--gold);}
.sec-p{font-size:0.88rem;line-height:2.1;font-weight:300;max-width:540px;margin-bottom:3.5rem;color:var(--muted);}

/* ── WHAT WE DO GRID ── */
.types-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;}
.type-card{
  background:var(--white);border:1px solid var(--border);border-radius:4px;
  padding:2.5rem 1.8rem;text-align:center;transition:all 0.35s;
  box-shadow:0 2px 15px rgba(184,144,42,0.05);position:relative;overflow:hidden;
}
.type-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold3),var(--gold));transform:scaleX(0);transition:transform 0.35s;transform-origin:left;}
.type-card:hover{transform:translateY(-7px);box-shadow:0 20px 50px rgba(184,144,42,0.14);border-color:var(--border2);}
.type-card:hover::after{transform:scaleX(1);}
.tc-icon{font-size:2.2rem;margin-bottom:1rem;display:block;}
.tc-name{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--text);letter-spacing:0.5px;display:block;margin-bottom:0.4rem;}
.tc-sub{font-size:0.72rem;color:var(--muted2);letter-spacing:0.3px;font-weight:300;line-height:1.6;}

/* ── GALLERY ── */
.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:3rem;}
.g-item{position:relative;overflow:hidden;border-radius:4px;cursor:pointer;}
.g-item:nth-child(1){grid-column:span 2;}
.g-item:nth-child(7){grid-column:span 2;}
.g-bg{width:100%;aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:4rem;transition:transform 0.5s ease;}
.g-item:nth-child(1) .g-bg{aspect-ratio:auto;height:400px;font-size:6rem;}
.g-item:nth-child(7) .g-bg{aspect-ratio:2/1;}
.g-item:hover .g-bg{transform:scale(1.06);}
.g-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,35,64,0.85) 0%,transparent 55%);opacity:0;transition:opacity 0.4s;display:flex;align-items:flex-end;padding:1.5rem;}
.g-item:hover .g-overlay{opacity:1;}
.g-label{}
.g-tag{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold2);font-weight:700;display:block;margin-bottom:0.3rem;}
.g-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:600;color:var(--white);}

.bg-wedding{background:linear-gradient(145deg,#fdf0f5,#fce8f0,#fdf5f8);}
.bg-baby-blue{background:linear-gradient(145deg,#EBF5FB,#D6EAF8,#EBF5FB);}
.bg-baby-pink{background:linear-gradient(145deg,#FEF9E7,#FDEBD0,#FEF9E7);}
.bg-birthday{background:linear-gradient(145deg,var(--gold-bg),var(--warm),var(--gold-bg));}
.bg-matric{background:linear-gradient(145deg,#E8F8F5,#D1F2EB,#E8F8F5);}
.bg-corporate{background:linear-gradient(145deg,#EBF5FB,#D6EAF8,#EBF5FB);}
.bg-gala{background:linear-gradient(145deg,var(--champagne),var(--warm),var(--gold-bg));}

/* ── PROCESS ── */
.process-wrap{background:var(--champagne);padding:7rem 5%;}
.process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-top:4rem;position:relative;}
.process-steps::before{content:'';position:absolute;top:30px;left:12.5%;right:12.5%;height:1px;background:var(--border2);}
.p-step{text-align:center;padding:0 0.8rem;}
.p-num{
  width:60px;height:60px;border-radius:50%;
  border:1.5px solid var(--gold2);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 1.5rem;
  font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--gold);
  background:var(--white);position:relative;z-index:1;
  box-shadow:0 4px 20px rgba(184,144,42,0.12);
}
.p-step h3{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--text);margin-bottom:0.6rem;}
.p-step p{color:var(--muted);font-size:0.8rem;line-height:1.9;font-weight:300;}

/* ── REVIEWS ── */
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.8rem;margin-top:3.5rem;}
.rev-card{
  background:var(--white);border-radius:4px;padding:2.8rem;
  border-bottom:3px solid var(--gold);
  box-shadow:0 4px 30px rgba(184,144,42,0.08);
  position:relative;
}
.rev-card::before{
  content:'\201C';
  font-family:'Cormorant Garamond',serif;font-size:7rem;
  color:var(--gold-bg);line-height:1;
  position:absolute;top:-1.5rem;left:1.5rem;
  pointer-events:none;
}
.stars{color:var(--gold);font-size:0.88rem;margin-bottom:1.2rem;letter-spacing:3px;}
.rev-text{
  font-family:'Cormorant Garamond',serif;font-style:italic;
  font-size:1.05rem;color:#3A2E1A;line-height:1.85;
  margin-bottom:1.8rem;padding-top:0.8rem;
}
.rev-author{display:flex;align-items:center;gap:0.9rem;}
.rev-avatar{
  width:44px;height:44px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold3));
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--white);
  flex-shrink:0;border:2px solid var(--gold3);
}
.rev-name{font-weight:700;font-size:0.88rem;color:var(--text);}
.rev-event{font-size:0.7rem;color:var(--muted2);letter-spacing:1px;margin-top:0.1rem;}

/* ── EVENTS PAGE CARDS ── */
.event-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:2rem;}
.ev-card{background:var(--white);border-radius:4px;padding:2.8rem;border-left:4px solid var(--gold);box-shadow:0 4px 25px rgba(184,144,42,0.08);transition:all 0.3s;}
.ev-card:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(184,144,42,0.14);}
.ev-card-icon{font-size:2.5rem;margin-bottom:1.2rem;}
.ev-card h3{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;margin-bottom:0.8rem;color:var(--text);}
.ev-card p{color:var(--muted);font-weight:300;line-height:1.9;font-size:0.88rem;}

/* ── PORTFOLIO ── */
.port-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-top:3rem;}
.port-item{background:var(--white);border:1px solid var(--border);border-radius:4px;overflow:hidden;transition:all 0.35s;box-shadow:0 4px 20px rgba(0,0,0,0.04);}
.port-item:first-child{grid-column:span 2;}
.port-item:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(184,144,42,0.12);border-color:var(--border2);}
.port-thumb{height:180px;display:flex;align-items:center;justify-content:center;font-size:3.8rem;}
.port-info{padding:1.3rem 1.6rem;}
.port-tag{color:var(--gold);font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;font-weight:700;}
.port-info h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;margin:0.25rem 0;color:var(--text);}
.port-info p{color:var(--muted);font-size:0.78rem;font-weight:300;}

/* ── CONTACT ── */
.contact-sec{background:linear-gradient(160deg,var(--offwhite) 0%,var(--champagne) 100%);padding:7rem 5%;}
.contact-inner{max-width:760px;margin:0 auto;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2.5rem;}
.ff{
  padding:1.1rem 1.3rem;background:var(--white);
  border:1.5px solid var(--border);border-radius:3px;
  color:var(--text);font-family:'Montserrat',sans-serif;font-size:0.85rem;
  outline:none;transition:border-color 0.3s;
}
.ff::placeholder{color:var(--muted2);}
.ff:focus{border-color:var(--gold);}
.ff option{background:var(--white);}
.ff-full{grid-column:span 2;}
.ff-submit{
  grid-column:span 2;background:var(--gold);color:var(--white);
  border:none;padding:1.2rem;font-size:0.75rem;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;cursor:pointer;
  font-family:'Montserrat',sans-serif;transition:all 0.3s;border-radius:2px;
}
.ff-submit:hover{background:var(--navy);transform:translateY(-2px);}
.contact-info-bar{display:flex;gap:3rem;flex-wrap:wrap;margin-top:3rem;padding-top:3rem;border-top:1px solid var(--border2);}
.ci-item{display:flex;flex-direction:column;gap:0.3rem;}
.ci-label{font-size:0.58rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:700;}
.ci-val{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--text);}
.ci-val a{color:var(--gold);text-decoration:none;}

/* ── CTA BAND ── */
.cta-band{background:var(--warm);border-top:1px solid var(--border2);padding:5.5rem 5%;text-align:center;}
.cta-band h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:700;color:var(--text);margin-bottom:0.8rem;}
.cta-band h2 em{color:var(--gold);font-style:italic;}
.cta-band p{color:var(--muted);margin-bottom:2.5rem;font-size:0.88rem;letter-spacing:0.5px;font-weight:300;}

/* ── FOOTER ── */
footer{background:var(--offwhite);padding:3rem 5%;border-top:1px solid var(--border2);}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.5rem;}
.footer-brand{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;letter-spacing:4px;color:var(--text);}
.footer-brand .g{color:var(--gold);}
.footer-right{text-align:right;}
.footer-right p{color:var(--muted2);font-size:0.75rem;line-height:1.9;}
.footer-right a{color:var(--gold);text-decoration:none;}
.footer-slogan{font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--muted);font-size:0.95rem;display:block;margin-bottom:0.3rem;}

.page{display:none;} .page.active{display:block;} #home{display:block;}

@media(max-width:900px){
  .hero{grid-template-columns:1fr;}
  .hero-right{display:none;}
  .process-steps{grid-template-columns:1fr 1fr;}
  .process-steps::before{display:none;}
  .gallery-grid{grid-template-columns:1fr 1fr;}
  .g-item:nth-child(1){grid-column:span 2;}
  .g-item:nth-child(7){grid-column:span 2;}
  .footer-inner{flex-direction:column;}
  .footer-right{text-align:center;}
}
</style>
</head>
<body>

<!-- ═══ NAV ═══ -->
<nav>
  <a href="#" class="nav-brand" onclick="showPage('home')">
    <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="25" cy="25" r="25" fill="var(--gold-bg)"/>
      <circle cx="25" cy="25" r="24" stroke="var(--border2)" stroke-width="1"/>
      <path d="M7 36 Q25 12 43 36" fill="rgba(184,144,42,0.1)" stroke="var(--gold)" stroke-width="2"/>
      <ellipse cx="15" cy="28" rx="7" ry="4" fill="white" opacity="0.9"/>
      <ellipse cx="22" cy="24" rx="5.5" ry="3.5" fill="white" opacity="0.9"/>
      <ellipse cx="36" cy="26" rx="6" ry="3.5" fill="white" opacity="0.8"/>
      <circle cx="25" cy="14" r="4" fill="var(--gold)"/>
      <line x1="25" y1="8" x2="25" y2="6" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="30" y1="10" x2="32" y2="8" stroke="var(--gold)" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="20" y1="10" x2="18" y2="8" stroke="var(--gold)" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="5" y1="38" x2="45" y2="38" stroke="var(--border2)" stroke-width="1"/>
      <circle cx="14" cy="43" r="2.5" fill="var(--gold)" opacity="0.5"/>
      <circle cx="25" cy="45" r="2.5" fill="var(--gold)" opacity="0.7"/>
      <circle cx="36" cy="43" r="2.5" fill="var(--gold)" opacity="0.5"/>
    </svg>
    <div class="nb-text">
      <span class="nb-name">SKY <span class="g">EVENTS</span> Co.</span>
      <span class="nb-sub">Where Vision Meets Spectacle</span>
    </div>
  </a>
  <ul>
    <li><a href="#" onclick="showPage('home')">Home</a></li>
    <li><a href="#" onclick="showPage('events')">Events</a></li>
    <li><a href="#" onclick="showPage('gallery')">Gallery</a></li>
    <li><a href="#" onclick="showPage('portfolio')">Portfolio</a></li>
    <li><a href="#" onclick="showPage('contact')" class="nav-cta">Plan Your Event</a></li>
  </ul>
</nav>

<!-- ═══════════════ HOME ═══════════════ -->
<div id="home" class="page active">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-deco"></div>
    <div class="hero-left">
      <div class="hero-pretitle"><div class="pre-line"></div><span class="pre-text">Luxury Event Specialists · Est. 2023</span></div>
      <h1>
        <span class="gold-h">SKY</span><br>
